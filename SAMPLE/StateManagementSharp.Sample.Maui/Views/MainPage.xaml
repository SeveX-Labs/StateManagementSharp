<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="StateManagementSharp.Sample.Maui.Views.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewModels="clr-namespace:StateManagementSharp.Sample.Maui.ViewModels"
    x:DataType="viewModels:MainPageViewModel"
    Title="{Binding ApplicationTitle.Value}"
    BackgroundColor="{StaticResource PageBackgroundColor}">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="16">

            <Label
                FontAttributes="Bold"
                FontSize="26"
                Text="{Binding ApplicationTitle.Value}"
                TextColor="{StaticResource PrimaryTextColor}" />
            <Label
                FontSize="13"
                TextColor="#5A6472"
                Text="Buttons only dispatch. The values and the log below update on their own — no manual refresh." />
            <Label
                FontSize="12"
                TextColor="#8A94A6"
                Text="Flow:  Button → Dispatch → Action/Mutation → StateChanged → Bind/Observe → UI" />

            <!-- ============ Automatic bindings (Bind) ============ -->
            <Border Stroke="#E1E5EA" StrokeThickness="1" Padding="14" BackgroundColor="#FFFFFF">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="8">
                    <Label FontAttributes="Bold" FontSize="18" Text="Automatic bindings (Bind)" />
                    <Label
                        FontSize="12"
                        TextColor="#8A94A6"
                        Text="Values the UI displays — raw or derived. Recomputed after every commit and pushed to the UI thread for you." />

                    <Grid ColumnDefinitions="130,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="4">
                        <Label Grid.Row="0" Grid.Column="0" FontAttributes="Bold" Text="Status:" />
                        <Label Grid.Row="0" Grid.Column="1" Text="{Binding StatusText.Value}" />

                        <Label Grid.Row="1" Grid.Column="0" FontAttributes="Bold" Text="Busy:" />
                        <Label Grid.Row="1" Grid.Column="1" Text="{Binding IsBusy.Value}" />

                        <Label Grid.Row="2" Grid.Column="0" FontAttributes="Bold" Text="Profile summary:" />
                        <Label Grid.Row="2" Grid.Column="1" Text="{Binding ProfileSummary.Value}" />

                        <Label Grid.Row="3" Grid.Column="0" FontAttributes="Bold" Text="Profile name:" />
                        <Label Grid.Row="3" Grid.Column="1" Text="{Binding ProfileName.Value}" />

                        <Label Grid.Row="4" Grid.Column="0" FontAttributes="Bold" Text="Email:" />
                        <Label Grid.Row="4" Grid.Column="1" Text="{Binding Email.Value}" />

                        <Label Grid.Row="5" Grid.Column="0" FontAttributes="Bold" Text="Has profile:" />
                        <Label Grid.Row="5" Grid.Column="1" Text="{Binding HasProfile.Value}" />
                    </Grid>

                    <Label
                        FontSize="11"
                        TextColor="#8A94A6"
                        Text="“Status” and “Profile summary” are DERIVED inside Bind — the state has no such field. No field is refreshed by hand." />
                </VerticalStackLayout>
            </Border>

            <!-- ============ Actions (dispatch only) ============ -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="12" RowDefinitions="Auto,Auto" RowSpacing="12">
                <Button Grid.Row="0" Grid.Column="0" Command="{Binding InitializeCommand}" Text="Initialize App" />
                <Button Grid.Row="0" Grid.Column="1" Command="{Binding ToggleBusyCommand}" Text="Toggle Busy" />
                <Button Grid.Row="1" Grid.Column="0" Command="{Binding LoadProfileCommand}" Text="Load Profile" />
                <Button
                    Grid.Row="1"
                    Grid.Column="1"
                    Command="{Binding ClearProfileCommand}"
                    IsEnabled="{Binding CanClearProfile.Value}"
                    Text="Clear Profile" />
            </Grid>
            <Label
                FontSize="11"
                TextColor="#8A94A6"
                Text="“Clear Profile” is enabled by a derived Bind value (CanClearProfile), so it disables itself when there is no profile." />

            <!-- ============ Reaction log (Observe) ============ -->
            <Border Stroke="#E1E5EA" StrokeThickness="1" Padding="14" BackgroundColor="#FFFFFF">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="8">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0" FontAttributes="Bold" FontSize="18" Text="Reaction log (Observe)" VerticalOptions="Center" />
                        <Button Grid.Column="1" Command="{Binding ClearLogCommand}" Text="Clear log" Padding="12,4" FontSize="13" />
                    </Grid>
                    <Label
                        FontSize="12"
                        TextColor="#8A94A6"
                        Text="Every line is written by an Observe reaction (side-effect). Tap “Load Profile” twice: the name reaction fires only ONCE — distinct-until-changed." />

                    <VerticalStackLayout BindableLayout.ItemsSource="{Binding ReactionLog}" Spacing="2">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="{x:Null}">
                                <Label Text="{Binding .}" FontSize="13" TextColor="#2B3038" />
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                        <BindableLayout.EmptyView>
                            <Label FontSize="12" TextColor="#8A94A6" Text="(no reactions yet — tap a button)" />
                        </BindableLayout.EmptyView>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
