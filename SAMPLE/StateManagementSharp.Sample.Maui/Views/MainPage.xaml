<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="StateManagementSharp.Sample.Maui.Views.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewModels="clr-namespace:StateManagementSharp.Sample.Maui.ViewModels"
    x:DataType="viewModels:MainPageViewModel"
    Title="{Binding ApplicationTitle}"
    BackgroundColor="{StaticResource PageBackgroundColor}">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="18">
            <Label
                FontAttributes="Bold"
                FontSize="28"
                Text="{Binding ApplicationTitle}"
                TextColor="{StaticResource PrimaryTextColor}" />

            <HorizontalStackLayout Spacing="8">
                <Label FontAttributes="Bold" Text="Busy:" />
                <Label Text="{Binding IsBusy}" />
            </HorizontalStackLayout>

            <BoxView HeightRequest="1" Color="#D6DAE0" />

            <VerticalStackLayout Spacing="6">
                <Label FontAttributes="Bold" FontSize="20" Text="Profile" />
                <Label Text="{Binding FirstName, StringFormat='First name: {0}', TargetNullValue='First name: -'}" />
                <Label Text="{Binding LastName, StringFormat='Last name: {0}', TargetNullValue='Last name: -'}" />
                <Label Text="{Binding Email, StringFormat='Email: {0}', TargetNullValue='Email: -'}" />
                <Label Text="{Binding IsProfileLoaded, StringFormat='Loaded: {0}'}" />
            </VerticalStackLayout>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="12" RowDefinitions="Auto,Auto" RowSpacing="12">
                <Button Grid.Row="0" Grid.Column="0" Command="{Binding InitializeCommand}" Text="Initialize App" />
                <Button Grid.Row="0" Grid.Column="1" Command="{Binding ToggleBusyCommand}" Text="Toggle Busy" />
                <Button Grid.Row="1" Grid.Column="0" Command="{Binding LoadProfileCommand}" Text="Load Profile" />
                <Button Grid.Row="1" Grid.Column="1" Command="{Binding ClearProfileCommand}" Text="Clear Profile" />
            </Grid>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
